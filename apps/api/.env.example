# Supabase — connection pooling (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Supabase — direct connection (used by prisma migrate deploy only)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET="replace-with-64-char-random-hex"
AUTH_SECRET="replace-with-64-char-random-hex"

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_CALLBACK_URL="https://api.moneyapp.click/api/auth/google/callback"

# Gmail — App Password (not your account password)
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# URLs
FRONTEND_URL="https://moneyapp.click"

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="https://moneyapp.click,https://www.moneyapp.click"

# Runtime
NODE_ENV="production"
PORT="8080"
