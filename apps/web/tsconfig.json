{
  "extends": "@repo/typescript-config/nextjs.json",
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@web/*": [
        "./*"
      ],
      "@web/components/*": [
        "./components/*"
      ],
      "@web/app/*": [
        "./app/*"
      ]
    },
    "strictNullChecks": true
  }
}
